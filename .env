# Имя сетевого интерфейса (можно узнать через команду ip a, обычно eth0 или ens3)
INTERFACE=eth0

# Порт, который атакуют (например, 443 для VLESS или 80/443 для Nginx)
TARGET_PORT=443

# Лимит пакетов от одного IP за интервал времени
PACKET_LIMIT=200

# Интервал проверки в секундах
CHECK_INTERVAL_SEC=2

# На сколько секунд банить IP (3600 = 1 час)
BAN_TIME_SEC=3600
